{
  "openapi": "3.0.0",
  "info": {
    "title": "Laravel Currency API",
    "version": "1.0.0",
    "description": "Currency CRUD API built with Laravel"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000/api",
      "description": "Laravel API server"
    }
  ],
  "paths": {
    "/currencies": {
      "get": {
        "summary": "Get all currencies",
        "responses": {
          "200": {
            "description": "List of currencies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Currency"
                  }
                },
                "example": [
                  {
                    "id": 1,
                    "code": "USD",
                    "name": "US Dollar",
                    "rate": 1.0
                  }
                ]
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create currency",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CurrencyRequest"
              },
              "example": {
                "code": "EUR",
                "name": "Euro",
                "rate": 0.92
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Currency created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Currency"
                }
              }
            }
          }
        }
      }
    },
    "/currencies/{id}": {
      "get": {
        "summary": "Get currency by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Currency found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Currency"
                }
              }
            }
          },
          "404": {
            "description": "Currency not found"
          }
        }
      },
      "patch": {
        "summary": "Update currency",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CurrencyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Currency updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Currency"
                }
              }
            }
          },
          "404": {
            "description": "Currency not found"
          }
        }
      },
      "delete": {
        "summary": "Delete currency",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Currency deleted"
          },
          "404": {
            "description": "Currency not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Currency": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true,
            "example": 1
          },
          "code": {
            "type": "string",
            "maxLength": 255,
            "example": "USD"
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "example": "US Dollar"
          },
          "rate": {
            "type": "number",
            "format": "float",
            "example": 1.0
          }
        }
      },
      "CurrencyRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "maxLength": 255,
            "example": "USD"
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "example": "US Dollar"
          },
          "rate": {
            "type": "number",
            "format": "float",
            "example": 1.0
          }
        },
        "required": ["code", "name", "rate"]
      }
    }
  }
}
